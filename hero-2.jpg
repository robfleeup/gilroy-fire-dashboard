const $=id=>document.getElementById(id);const fmt=n=>Number(n||0).toLocaleString();
function clock(){const d=new Date();$('clock').textContent=d.toLocaleTimeString([],{hour:'numeric',minute:'2-digit'});$('date').textContent=d.toLocaleDateString([],{weekday:'long',month:'long',day:'numeric',year:'numeric'});}clock();setInterval(clock,1000);
function unitName(u){return u.startsWith('E')?'Engine':u.startsWith('RM')?'Rescue Medic':u.startsWith('T')?'Truck':'Chief Officer'}
async function historical(){const d=await fetch('/api/historical').then(r=>r.json());$('kpis').innerHTML=[['2026 INCIDENTS YTD',fmt(d.total_incidents),'Verified department reports'],['INCIDENTS THIS MONTH',fmt(d.incidents_month),'Current reporting month'],['INCIDENTS TODAY',fmt(d.incidents_today),'Reporting day'],['AVERAGE DAILY INCIDENTS',d.average_daily,'2026 YTD'],['EMS SHARE',d.medical_percent+'%','Percent of incidents'],['UNIT RESPONSES',fmt(d.unit_responses_total),'Listed Gilroy apparatus']].map(x=>`<article class="kpi"><span>${x[0]}</span><strong>${x[1]}</strong><small>${x[2]}</small></article>`).join('');
const order=['E47','E48','E49','E50','RM49','E650','T47','B47','B48','B49','B50'];$('units').innerHTML=order.map(u=>{const v=d.first_arriving[u]||{};return `<article class="unit"><div class="unit-head"><b>${u}</b><span>${unitName(u)}</span></div><div class="periods"><div><strong>${fmt(v.today)}</strong><small>Day</small></div><div><strong>${fmt(v.month)}</strong><small>Month</small></div><div><strong>${fmt(v.ytd)}</strong><small>YTD</small></div></div></article>`}).join('')+`<article class="unit aid"><div class="unit-head"><b>AID</b><span>Mutual Aid</span></div><div class="periods"><div><strong>${fmt(d.aid_received_ytd)}</strong><small>Received YTD</small></div><div><strong>${d.aid_given_ytd??'—'}</strong><small>Given YTD</small></div></div><p>${d.aid_note}</p></article>`;
$('report-date').textContent='Reporting through '+new Date(d.as_of).toLocaleDateString();const max=Math.max(...d.monthly.map(x=>x.count));$('monthly').innerHTML=d.monthly.map(x=>`<div class="bar"><div class="bar-top"><span>${new Date(x.month+'-02').toLocaleDateString([],{month:'short'})}</span><b>${fmt(x.count)}</b></div><div class="track"><i style="width:${x.count/max*100}%"></i></div></div>`).join('');$('ems-share').textContent=d.medical_percent+'%';$('donut').style.setProperty('--pct',d.medical_percent);$('types').innerHTML=d.top_types.slice(0,6).map((x,i)=>`<div class="rank"><b>${i+1}</b><div><b>${x.type}</b><span>${fmt(x.count)} incidents</span></div></div>`).join('');}
async function live(){const d=await fetch('/api/live').then(r=>r.json());const vals=[['ACTIVE INCIDENTS',d.active_incidents],['INCIDENTS TODAY',d.incidents_today],['EMS TODAY',d.ems_today],['FIRE & OTHER',d.fire_other_today],['UNITS COMMITTED',d.gilroy_units_committed],['CHIEF OFFICERS',d.chiefs_committed],['ALS AMBULANCES',d.als_assigned],['BLS AMBULANCES',d.bls_assigned]];$('ops-grid').innerHTML=vals.map(x=>`<div><strong>${fmt(x[1])}</strong><span>${x[0]}</span></div>`).join('');$('live-source').textContent=d.source||'Unavailable';$('updated').textContent=new Date(d.updated_at).toLocaleTimeString([],{hour:'numeric',minute:'2-digit'});$('feed').innerHTML=d.recent?.length?d.recent.map(x=>`<div class="feed-row"><div><b>${x.type}</b><span>${x.received_at?new Date(x.received_at).toLocaleTimeString([],{hour:'numeric',minute:'2-digit'}):''}</span></div><div><b>${x.address}</b><span>${(x.units||[]).join(', ')||'No public unit listing'}</span></div><div>${(x.units||[]).join(', ')||'—'}</div><div class="pill">${x.is_active?'Active':'Recent'}</div></div>`).join(''):`<p class="muted" style="padding:24px">No public incidents are currently available. Source: ${d.source||'Unavailable'}.</p>`;}
async function weather(){const d=await fetch('/api/weather').then(r=>r.json());if(!d.available){$('conditions').textContent='Weather unavailable';return;}$('temp').textContent=(d.temperature_f??'--')+'°';$('conditions').textContent=d.description||'Current conditions';$('wind').textContent=[d.wind_direction,d.wind_mph].filter(Boolean).join(' ')||'—';$('humidity').textContent=d.humidity==null?'—':Math.round(d.humidity)+'%';$('rain').textContent=d.probability==null?'—':Math.round(d.probability)+'%';}
async function alerts(){const d=await fetch('/api/alerts').then(r=>r.json());if(d.alerts?.length){$('alert-title').textContent=d.alerts[0].event||'Active weather alert';$('alert-copy').textContent=d.alerts[0].headline||'See National Weather Service for details';}else{$('alert-title').textContent='No active weather alerts';$('alert-copy').textContent='No National Weather Service alerts are currently listed for Gilroy.';}}
async function load(){await Promise.allSettled([historical(),live(),weather(),alerts()]);}load();setInterval(live,60000);setInterval(()=>{weather();alerts()},300000);
