:root{--report-red:#be302a;--report-navy:#111d2d;--report-blue:#233a55;--report-cream:#f4f1ea;--report-gold:#c9a66b}.report-body{background:#f5f2eb}.report-top{height:84px;padding:9px 5vw;background:#fff;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #dfe4e8;position:relative;z-index:31}.report-brand{display:flex;align-items:center;gap:14px;color:var(--report-navy);text-decoration:none}.report-brand img{width:67px;height:64px;object-fit:contain}.report-brand strong,.report-brand small{display:block}.report-brand strong{font-size:20px}.report-brand small{color:#718095;margin-top:4px}.back-dashboard{color:var(--report-navy);font-weight:850;text-decoration:none}.report-chapters{height:52px;top:0;justify-content:center;gap:27px;padding:0 18px;overflow-x:auto;white-space:nowrap}.report-chapters a{font-size:12px}.report-main{max-width:none;margin:0;padding:0}.report-hero{height:calc(100vh - 136px);min-height:650px;position:relative;overflow:hidden}.report-hero-bg{position:absolute;inset:0;background:url('../images/hero-6.jpg') center 35%/cover;transform:scale(1.03)}.report-hero-shade{position:absolute;inset:0;background:linear-gradient(90deg,rgba(6,14,25,.94) 0%,rgba(8,20,35,.72) 48%,rgba(8,20,35,.22) 100%)}.report-hero-copy{position:absolute;left:8vw;top:50%;transform:translateY(-50%);max-width:760px;color:#fff}.eyebrow{font-size:11px;letter-spacing:.18em;font-weight:900;color:#f2aaa6}.eyebrow.dark{color:var(--report-red)}.report-hero h1{font-size:clamp(54px,7vw,96px);line-height:.94;margin:18px 0 24px;letter-spacing:-.05em}.report-hero-copy>p:not(.eyebrow){font-size:19px;line-height:1.65;color:#dae2ea;max-width:690px}.hero-actions{display:flex;gap:12px;margin-top:30px}.report-primary,.report-secondary{padding:13px 18px;border-radius:999px;text-decoration:none;font-weight:850}.report-primary{background:var(--report-red);color:#fff}.report-secondary{border:1px solid rgba(255,255,255,.34);color:#fff;background:rgba(255,255,255,.08)}.report-section{padding:100px max(6vw,30px);max-width:1600px;margin:auto}.report-section.intro{padding-top:92px;text-align:center}.section-kicker{font-size:12px;color:var(--report-red);font-weight:900;letter-spacing:.18em}.annual-kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin:36px 0 70px}.annual-kpis article{background:#fff;padding:35px 20px;border-radius:20px;border:1px solid #dde3e8;box-shadow:0 20px 50px rgba(17,29,45,.09)}.annual-kpis strong{display:block;font-size:52px;letter-spacing:-.04em}.annual-kpis span{display:block;color:#6e7b8d;margin-top:8px;font-size:13px;text-transform:uppercase;letter-spacing:.08em}.report-section blockquote{font-size:30px;line-height:1.4;max-width:970px;margin:auto;color:#26384d}.report-section cite{display:block;font-size:13px;color:#738093;margin-top:18px;font-style:normal;text-transform:uppercase;letter-spacing:.1em}.chapter-heading{display:flex;align-items:center;gap:20px;margin-bottom:38px}.chapter-heading>span{width:56px;height:56px;border-radius:50%;background:var(--report-red);color:#fff;display:grid;place-items:center;font-weight:900}.chapter-heading p,.chapter-heading h2{margin:0}.chapter-heading p{font-size:11px;letter-spacing:.16em;color:var(--report-red);font-weight:900}.chapter-heading h2{font-size:48px;letter-spacing:-.035em;margin-top:6px}.chapter-heading.light p{color:#f2aaa6}.chapter-heading.light h2{color:#fff}.split-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:22px}.report-card{background:#fff;border-radius:22px;padding:34px;border:1px solid #dde3e8;box-shadow:0 18px 48px rgba(17,29,45,.09)}.demand-donut-card{display:grid;grid-template-columns:330px 1fr;gap:35px;align-items:center}.interactive-donut{width:300px;height:300px;border-radius:50%;background:conic-gradient(#be302a 0 69.6%,#294966 69.6% 79.6%,#54728a 79.6% 87.6%,#8ca1b2 87.6% 93.5%,#c9a66b 93.5% 98.3%,#747c83 98.3% 99.8%,#d8dce0 99.8%);display:grid;place-items:center;position:relative}.interactive-donut:before{content:"";width:182px;height:182px;border-radius:50%;background:#fff;position:absolute}.donut-center{position:relative;text-align:center}.donut-center strong{display:block;font-size:42px}.donut-center span{font-size:11px;color:#768395;text-transform:uppercase}.legend{display:grid;gap:8px}.legend button{border:0;background:#f2f5f7;border-radius:10px;padding:11px 12px;display:grid;grid-template-columns:14px 1fr auto;gap:10px;text-align:left;color:#24354a;cursor:pointer}.legend i{width:10px;height:10px;border-radius:3px;margin-top:2px}.legend b{font-size:11px}.c1{background:#be302a}.c2{background:#294966}.c3{background:#54728a}.c4{background:#8ca1b2}.c5{background:#c9a66b}.c6{background:#747c83}.narrative h3{font-size:31px;line-height:1.2}.why-list{display:grid;gap:13px;margin-top:26px}.why-list>div{display:grid;grid-template-columns:45px 1fr;gap:15px;padding:16px;background:#f2f5f7;border-radius:13px}.why-list b{color:var(--report-red)}.why-list strong,.why-list span{display:block}.why-list span{font-size:13px;color:#657487;line-height:1.5}.why-list strong{color:#203248;font-size:15px;margin-bottom:4px}.dark-section{max-width:none;background:var(--report-navy);color:#fff}.dark-section>*{max-width:1420px;margin-left:auto;margin-right:auto}.response-summary{display:grid;grid-template-columns:repeat(3,1fr);gap:15px;margin-bottom:22px}.response-summary div{padding:26px;background:#1b2b40;border:1px solid #2d415a;border-radius:17px}.response-summary strong{display:block;font-size:43px}.response-summary span{color:#aebaca;font-size:12px;text-transform:uppercase}.timeline-card,.monthly-card{background:#fff;color:var(--report-navy);border-radius:22px;padding:34px;margin-top:22px}.timeline-card{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}.response-step b,.response-step span,.response-step small{display:block}.response-step b{font-size:31px}.response-step span{font-weight:850;margin:8px 0}.response-step small{color:#758293}.response-step i{height:8px;background:#e3e8ec;border-radius:99px;display:block;overflow:hidden;margin:20px 0 12px}.response-step i:after{content:"";display:block;width:var(--fill);height:100%;background:var(--report-red);border-radius:99px;transform-origin:left;animation:grow 1.2s ease both}.response-step.total{padding-left:20px;border-left:1px solid #dbe1e6}.chart-head{display:flex;justify-content:space-between;align-items:end}.chart-head h3{font-size:32px;margin:7px 0 0}.chart-head>div:last-child{text-align:right}.chart-head strong,.chart-head span{display:block}.chart-head strong{font-size:35px;color:var(--report-red)}.annual-chart{height:310px;margin-top:28px}.annual-chart svg{width:100%;height:100%;overflow:visible}.chart-legend{display:flex;gap:25px;justify-content:center;margin-top:10px}.chart-legend span{font-size:11px;color:#6f7d8e}.chart-legend i{display:inline-block;width:20px;height:4px;background:var(--report-red);margin-right:7px;vertical-align:middle}.chart-legend span:last-child i{background:#294966}.capacity-grid{display:grid;grid-template-columns:1.1fr .9fr .9fr;gap:18px}.staff-scale{display:grid;grid-template-columns:repeat(3,1fr);gap:15px;height:270px;align-items:end;margin-top:18px}.staff-scale div{height:var(--level);background:linear-gradient(#c94640,#aa2824);border-radius:13px 13px 4px 4px;padding:20px;color:#fff}.staff-scale strong,.staff-scale span{display:block}.staff-scale strong{font-size:33px}.staff-scale span{font-size:10px;text-transform:uppercase;margin-top:5px}.capacity-note{display:flex;gap:14px;align-items:center;margin-top:20px}.capacity-note strong{font-size:37px;color:var(--report-red)}.capacity-note span{color:#687688;line-height:1.45}.big-stat strong{display:block;font-size:70px;color:var(--report-red);margin-top:25px}.big-stat span{color:#6c798a;text-transform:uppercase;font-size:11px}.overlap-card>p,.aid-card>p{color:#687688;line-height:1.65}.pressure-meter{margin-top:25px}.pressure-meter i{display:block;height:14px;border-radius:99px;background:linear-gradient(90deg,#5ba56f,#d1b04e,#be302a);position:relative}.pressure-meter i:after{content:"";position:absolute;left:60%;top:-6px;width:5px;height:26px;background:#16263a;border-radius:4px}.pressure-meter b{display:block;font-size:12px;line-height:1.5;margin-top:15px}.aid-flow{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:12px;text-align:center;margin:37px 0}.aid-flow strong,.aid-flow span{display:block}.aid-flow strong{font-size:50px}.aid-flow span{font-size:11px;color:#6c798a;text-transform:uppercase}.aid-flow>b{color:var(--report-red)}.apparatus-section{max-width:none;background:linear-gradient(135deg,#18283c,#29435f);color:#fff}.apparatus-section>*{max-width:1420px;margin-left:auto;margin-right:auto}.apparatus-tabs{display:flex;gap:9px;overflow:auto;padding-bottom:14px}.apparatus-tabs button{border:1px solid #61758b;background:transparent;color:#fff;border-radius:999px;padding:10px 18px;font-weight:850;cursor:pointer}.apparatus-tabs button.active{background:var(--report-red);border-color:var(--report-red)}.apparatus-detail{background:#fff;color:var(--report-navy);border-radius:22px;padding:34px;display:grid;grid-template-columns:1.4fr repeat(3,1fr);gap:24px;align-items:center;margin-top:18px}.apparatus-detail h3{font-size:38px;margin:5px 0}.apparatus-detail p{color:#6b798b}.unit-metric{border-left:1px solid #dce2e7;padding-left:24px}.unit-metric strong,.unit-metric span{display:block}.unit-metric strong{font-size:34px}.unit-metric span{color:#6d7a8b;font-size:11px;text-transform:uppercase}.training-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:15px}.training-card{background:#fff;border:1px solid #dce2e7;border-radius:18px;padding:25px;box-shadow:0 16px 40px rgba(17,29,45,.07)}.training-card span,.training-card strong,.training-card small{display:block}.training-card span{font-weight:850;min-height:40px}.training-card strong{font-size:52px;margin-top:18px}.training-card small{color:#6f7d8e;text-transform:uppercase}.training-card i{display:block;height:8px;background:#e8ecef;border-radius:99px;margin-top:24px;overflow:hidden}.training-card i:after{content:"";display:block;width:var(--progress);height:100%;background:var(--report-red);animation:grow 1.2s ease both}.training-card.accent{background:var(--report-navy);color:#fff}.priorities{max-width:none;background:#101c2b;color:#fff}.priorities>*{max-width:1420px;margin-left:auto;margin-right:auto}.priority-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14px}.priority-grid article{background:#1b2b40;border:1px solid #30455e;border-radius:18px;padding:25px;min-height:250px}.priority-grid b{color:#f0aaa6}.priority-grid h3{font-size:20px;margin:40px 0 12px}.priority-grid p{color:#b6c2d0;line-height:1.55;font-size:13px}.report-close{display:grid;grid-template-columns:140px 1fr;gap:30px;align-items:center;margin-top:80px;padding-top:45px;border-top:1px solid #31455c}.report-close img{width:130px;background:#fff;border-radius:17px;padding:8px}.report-close p{color:#f0aaa6;text-transform:uppercase;font-size:11px;letter-spacing:.15em}.report-close h2{font-size:36px;max-width:1050px}.report-close a{color:#fff;font-weight:850}.reveal{opacity:0;transform:translateY(28px);transition:.8s ease}.reveal.visible{opacity:1;transform:none}@keyframes grow{from{width:0}}@media(max-width:1050px){.annual-kpis{grid-template-columns:1fr 1fr}.split-grid,.capacity-grid{grid-template-columns:1fr}.timeline-card{grid-template-columns:1fr 1fr}.apparatus-detail{grid-template-columns:1fr 1fr}.priority-grid{grid-template-columns:1fr 1fr}.demand-donut-card{grid-template-columns:1fr}.interactive-donut{margin:auto}.training-grid{grid-template-columns:1fr 1fr}}@media(max-width:700px){.report-top{height:72px}.report-brand img{width:54px;height:52px}.report-brand strong{font-size:15px}.back-dashboard{font-size:12px}.report-chapters{justify-content:flex-start}.report-hero{height:720px}.report-hero-copy{left:7vw;right:7vw}.report-hero h1{font-size:54px}.hero-actions{flex-direction:column;align-items:flex-start}.report-section{padding:72px 22px}.annual-kpis,.response-summary,.timeline-card,.staff-scale,.training-grid,.priority-grid{grid-template-columns:1fr}.chapter-heading h2{font-size:38px}.report-section blockquote{font-size:23px}.demand-donut-card{padding:22px}.interactive-donut{width:260px;height:260px}.apparatus-detail{grid-template-columns:1fr}.unit-metric{border-left:0;border-top:1px solid #dce2e7;padding:18px 0 0}.chart-head{align-items:flex-start;gap:15px}.priority-grid article{min-height:0}.report-close{grid-template-columns:1fr}.report-close h2{font-size:27px}}
