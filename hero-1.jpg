:root{--navy:#0b1f33;--navy-2:#102a43;--red:#8f1823;--gold:#c59a3e;--paper:#eef1f4;--white:#fff;--muted:#aab7c4;--line:rgba(255,255,255,.15)}*{box-sizing:border-box}html,body{height:100%;margin:0}body{font-family:Inter,Arial,sans-serif;background:#081625;color:var(--white);overflow:hidden}.report-header{height:76px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:0 clamp(14px,3vw,42px);background:rgba(7,21,35,.96);border-bottom:1px solid var(--line);position:relative;z-index:30}.back-link{display:flex;align-items:center;gap:10px;color:#fff;text-decoration:none;font-size:13px;font-weight:800}.back-link>span:first-child{font-size:22px}.report-title{text-align:center}.report-title strong,.report-title span{display:block}.report-title strong{font-size:17px;letter-spacing:.02em}.report-title span{font-size:9px;color:#d4a643;text-transform:uppercase;letter-spacing:.12em;margin-top:5px}.header-actions{justify-self:end;display:flex;gap:8px}.icon-button{height:38px;min-width:42px;border:1px solid rgba(255,255,255,.19);border-radius:10px;background:rgba(255,255,255,.07);color:#fff;font-weight:900;display:grid;place-items:center;text-decoration:none;cursor:pointer}.viewer{height:calc(100vh - 76px);display:grid;grid-template-rows:minmax(0,1fr) 74px 28px}.slide-stage{position:relative;display:grid;place-items:center;padding:20px 72px 10px;overflow:hidden;background:radial-gradient(circle at center,#173450 0,#081625 70%)}.slide-shell{height:100%;width:100%;display:grid;place-items:center;position:relative}.slide-shell img{max-width:100%;max-height:100%;width:auto;height:auto;aspect-ratio:16/9;object-fit:contain;background:#fff;box-shadow:0 25px 70px rgba(0,0,0,.45);opacity:0;transform:scale(.992);transition:opacity .24s ease,transform .24s ease}.slide-shell img.ready{opacity:1;transform:scale(1)}.loading{position:absolute;color:#cfd8e2;font-size:13px}.edge-control{position:absolute;top:50%;transform:translateY(-50%);width:48px;height:96px;border:1px solid rgba(255,255,255,.15);background:rgba(8,22,37,.72);color:#fff;border-radius:14px;cursor:pointer;opacity:.72;transition:.2s}.edge-control:hover{opacity:1;background:rgba(143,24,35,.86)}.edge-control span{font-size:42px;font-weight:200}.previous{left:14px}.next{right:14px}.viewer-controls{display:grid;grid-template-columns:140px minmax(250px,760px) 140px;align-items:center;justify-content:center;gap:24px;padding:10px 24px;border-top:1px solid var(--line);background:#0a1b2d}.text-control{border:0;background:transparent;color:#fff;font-weight:850;cursor:pointer;padding:12px}.text-control:disabled,.edge-control:disabled{opacity:.22;cursor:default}.progress-area{min-width:0}.slide-label{display:flex;justify-content:space-between;align-items:center;font-size:11px;margin-bottom:8px}.slide-label strong{color:#e2b24c;letter-spacing:.04em}.slide-label span{color:#b6c1cc}input[type=range]{width:100%;accent-color:var(--red);cursor:pointer}.viewer-help{text-align:center;color:#738496;font-size:9px;text-transform:uppercase;letter-spacing:.13em;background:#081625;padding-top:7px}.chapter-panel{position:fixed;top:0;right:0;width:min(420px,90vw);height:100%;background:#f5f6f7;color:#102033;z-index:60;transform:translateX(102%);transition:transform .25s ease;box-shadow:-20px 0 70px rgba(0,0,0,.35);display:grid;grid-template-rows:auto 1fr auto}.chapter-panel.open{transform:translateX(0)}.panel-shade{position:fixed;inset:0;background:rgba(0,0,0,.58);z-index:55;opacity:0;pointer-events:none;transition:.25s}.panel-shade.open{opacity:1;pointer-events:auto}.chapter-panel-head{display:flex;justify-content:space-between;align-items:center;padding:24px;border-bottom:1px solid #d8dee5}.chapter-panel-head strong,.chapter-panel-head span{display:block}.chapter-panel-head strong{font-size:20px}.chapter-panel-head span{font-size:11px;color:#697788;margin-top:3px}.chapter-panel-head button{border:0;background:transparent;font-size:30px;cursor:pointer}.chapters{overflow:auto;padding:10px}.chapters button{width:100%;border:0;background:transparent;text-align:left;padding:14px;border-radius:12px;display:grid;grid-template-columns:46px 1fr;align-items:center;cursor:pointer;color:#102033}.chapters button:hover,.chapters button.active{background:#e5e9ed}.chapters b{color:var(--red);font-size:13px}.chapters span{font-weight:800;font-size:13px}.chapter-panel-foot{padding:20px 24px;border-top:1px solid #d8dee5}.chapter-panel-foot a{color:var(--red);font-weight:850;text-decoration:none}.fade-out{opacity:0!important;transform:scale(.992)!important}@media(max-width:760px){.report-header{height:64px;grid-template-columns:auto 1fr auto;padding:0 10px}.report-title{text-align:left;padding-left:12px}.report-title strong{font-size:13px}.report-title span{display:none}.back-link span:last-child{display:none}.desktop-only{display:none}.viewer{height:calc(100vh - 64px);grid-template-rows:minmax(0,1fr) 66px 22px}.slide-stage{padding:12px 8px}.slide-shell img{width:100%;height:auto}.edge-control{display:none}.viewer-controls{grid-template-columns:76px 1fr 76px;gap:5px;padding:7px 6px}.text-control{font-size:0}.text-control:first-child:after{content:'←';font-size:24px}.text-control:last-child:after{content:'→';font-size:24px}.slide-label{font-size:10px}.viewer-help{font-size:7px}.chapter-panel{width:92vw}}@media(orientation:landscape) and (max-height:600px){.report-header{height:52px}.viewer{height:calc(100vh - 52px);grid-template-rows:minmax(0,1fr) 48px}.viewer-help{display:none}.viewer-controls{padding:2px 14px}.slide-label{margin-bottom:2px}.slide-stage{padding:5px 58px}.report-title span{display:none}}@media(prefers-reduced-motion:reduce){*{transition:none!important}}
