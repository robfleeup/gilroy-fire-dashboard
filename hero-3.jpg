const formatNumber = n => Number(n).toLocaleString();
const counterObserver = new IntersectionObserver(entries => entries.forEach(entry => {
  if (!entry.isIntersecting || entry.target.dataset.done) return;
  entry.target.dataset.done = '1';
  const target = Number(entry.target.dataset.target || 0), suffix = entry.target.dataset.suffix || '';
  const start = performance.now(), duration = 1200;
  const tick = now => { const p=Math.min(1,(now-start)/duration); entry.target.textContent=formatNumber(Math.round(target*(1-Math.pow(1-p,3))))+suffix; if(p<1) requestAnimationFrame(tick); };
  requestAnimationFrame(tick);
}), {threshold:.35});
document.querySelectorAll('.count').forEach(el=>counterObserver.observe(el));

document.querySelectorAll('.reveal').forEach(el=>new IntersectionObserver(([e],o)=>{if(e.isIntersecting){el.classList.add('visible');o.disconnect();}}, {threshold:.15}).observe(el));

const center=document.querySelector('.donut-center');
document.querySelectorAll('.legend button').forEach(btn=>btn.addEventListener('mouseenter',()=>{center.innerHTML=`<strong>${btn.dataset.value}</strong><span>${btn.dataset.label} • ${btn.dataset.share}</span>`;}));
document.querySelector('.legend')?.addEventListener('mouseleave',()=>{center.innerHTML='<strong>7,014</strong><span>Total incidents</span>';});

const months=['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
const incidents=[563,552,588,562,570,606,655,603,568,585,580,582];
const responses=[685,679,721,689,706,753,857,741,700,735,723,712];
const chart=document.getElementById('annual-chart');
if(chart){
  const W=1100,H=300,P=40,max=900,x=i=>P+i*((W-2*P)/11),y=v=>H-P-(v/max)*(H-2*P);
  const path=a=>a.map((v,i)=>(i?'L':'M')+x(i)+','+y(v)).join(' ');
  chart.innerHTML=`<svg viewBox="0 0 ${W} ${H}" role="img"><g>${[0,300,600,900].map(v=>`<line x1="${P}" x2="${W-P}" y1="${y(v)}" y2="${y(v)}" stroke="#dce2e7"/><text x="0" y="${y(v)+4}" font-size="11" fill="#718095">${v}</text>`).join('')}</g><path d="${path(responses)}" fill="none" stroke="#294966" stroke-width="5" stroke-linecap="round"/><path d="${path(incidents)}" fill="none" stroke="#be302a" stroke-width="5" stroke-linecap="round"/>${incidents.map((v,i)=>`<g><circle cx="${x(i)}" cy="${y(v)}" r="6" fill="#be302a"><title>${months[i]}: ${v} incidents</title></circle><circle cx="${x(i)}" cy="${y(responses[i])}" r="6" fill="#294966"><title>${months[i]}: ${responses[i]} unit responses</title></circle><text x="${x(i)}" y="${H-8}" text-anchor="middle" font-size="10" fill="#718095">${months[i]}</text></g>`).join('')}</svg>`;
}

const units={E47:{name:'Engine 47',note:'Chestnut Station frontline engine.',responses:'2,569',avg:'7:07',p90:'10:09'},E48:{name:'Engine 48',note:'Las Animas Station frontline engine and highest analyzed workload.',responses:'2,849',avg:'5:42',p90:'8:48'},E49:{name:'Engine 49',note:'Sunrise Station frontline engine.',responses:'1,600',avg:'6:43',p90:'9:54'},E50:{name:'Engine 50',note:'Santa Teresa response capacity.',responses:'454',avg:'7:27',p90:'10:54'},E650:{name:'Engine 650',note:'Additional Santa Teresa response resource.',responses:'236',avg:'7:14',p90:'10:41'},RM49:{name:'Rescue Medic 49',note:'Sunrise Station ALS transport resource.',responses:'86',avg:'6:36',p90:'10:56'},T47:{name:'Truck 47',note:'Chestnut Station cross-staffed truck company.',responses:'190',avg:'7:10',p90:'11:09'}};
document.querySelectorAll('.apparatus-tabs button').forEach(btn=>btn.addEventListener('click',()=>{document.querySelectorAll('.apparatus-tabs button').forEach(b=>b.classList.remove('active'));btn.classList.add('active');const u=units[btn.dataset.unit];document.getElementById('unit-name').textContent=u.name;document.getElementById('unit-note').textContent=u.note;document.getElementById('unit-responses').textContent=u.responses;document.getElementById('unit-average').textContent=u.avg;document.getElementById('unit-p90').textContent=u.p90;}));

const sections=[...document.querySelectorAll('.report-section[id],.report-hero[id]')];
const navLinks=[...document.querySelectorAll('.report-chapters a')];
new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){navLinks.forEach(a=>a.classList.toggle('active',a.getAttribute('href')==='#'+e.target.id));}});},{rootMargin:'-25% 0px -60% 0px'}).observe?.(sections[0]);
const spy=new IntersectionObserver(entries=>entries.forEach(e=>{if(e.isIntersecting) navLinks.forEach(a=>a.classList.toggle('active',a.getAttribute('href')==='#'+e.target.id));}),{rootMargin:'-25% 0px -60% 0px'});sections.forEach(s=>spy.observe(s));
